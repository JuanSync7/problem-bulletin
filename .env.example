# Aion Bulletin — example environment file.
#
# IMPORTANT: every value below is a PLACEHOLDER, not a safe default.
# Copy this file to ``.env`` and replace each value before booting the
# app in any environment (including local dev). The Settings model in
# ``app/config.py`` enforces presence and (for ``JWT_SECRET``)
# minimum length — boot will fail-fast if a placeholder leaks through.
# See ``.claude/lessons-learned/v2.10-wp05-diagnosis.md`` for the
# fail-fast contract this file pairs with.
#
DATABASE_URL=postgresql+asyncpg://aion:__set_me__@postgres:28432/aion_bulletin  # REQ-916; placeholder, set real DB password
AZURE_TENANT_ID=__set_me__  # REQ-504; placeholder, set tenant GUID
AZURE_CLIENT_ID=__set_me__  # REQ-504; placeholder, set client GUID
AZURE_CLIENT_SECRET=__set_me__  # REQ-504; placeholder, set real Azure client secret
JWT_SECRET=__set_me_to_a_random_secret_at_least_32_chars__  # REQ-108; placeholder, MUST be ≥32 random chars in real envs
SMTP_HOST=__set_me__  # REQ-104; placeholder, set real SMTP host
SMTP_PORT=587  # REQ-104
SMTP_FROM=__set_me__  # REQ-104; placeholder, set sender address
APP_NAME=Aion Bulletin
DEV_AUTH_BYPASS=false
ENVIRONMENT=development
STORAGE_PATH=/data/attachments  # REQ-404
BASE_URL=http://localhost:28080  # REQ-104; safe for local dev, override per deploy
# TEAMS_WEBHOOK_URL=https://example.com/webhook  # optional, uncomment and set if needed

# --- Agent-Kanban observability (Task C4) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # NFR-906; jaeger all-in-one OTLP gRPC
